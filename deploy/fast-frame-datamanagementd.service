[Unit]
Description=Fast-Frame Data Management Daemon
After=network.target
Wants=network.target

[Service]
Type=simple
User=fast-frame
Group=fast-frame
WorkingDirectory=/opt/fast-frame
ExecStart=/opt/fast-frame/datamanagementd \
  -socket-path /tmp/fast-frame-datamanagement.sock \
  -sqlite-path /var/lib/fast-frame/datamanagement/datamanagementd.db \
  -version 1.0.0
Restart=always
RestartSec=5s
LimitNOFILE=100000
NoNewPrivileges=true
PrivateTmp=false

[Install]
WantedBy=multi-user.target
